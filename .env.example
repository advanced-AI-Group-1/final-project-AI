# FastAPI 애플리케이션 설정
# 개발 환경에서는 true, 프로덕션 환경에서는 false로 설정
DEBUG=false
# 환경 설정: development 또는 production
ENV=production
# 코드 변경 시 자동 리로드 (개발 환경에서만 true로 설정)
RELOAD=false


# Gunicorn 워커 프로세스 수 (CPU 코어 수 * 2 + 1이 권장됨)
WORKERS=4
# 바인딩할 주소 및 포트
BIND=0.0.0.0:8000

# 데이터베이스 설정
# SQLite 데이터베이스 URL
DATABASE_URL=sqlite+aiosqlite:///./data/finance_ai.db
# PostgreSQL 데이터베이스 URL 예시
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# API 설정
API_V1_STR=/v1

# 벡터 저장소 설정
VECTOR_STORE_PATH=data/vector_store

# VoyageAI API 키 (임베딩 생성용)
# 실제 API 키로 대체하세요
VOYAGE_API_KEY=your-voyage-api-key-here

# OpenAI API 키 (LLM용, 필요한 경우 설정)
OPENAI_API_KEY=your-openai-api-key-here

# LLM 설정
# 사용할 LLM 모델 (예: gpt-4, gpt-3.5-turbo 등)
DEFAULT_LLM_MODEL=gpt-4.1-mini
# 모델의 창의성 조절 (0.0 ~ 1.0, 낮을수록 더 결정적인 응답)
LLM_TEMPERATURE=0.2

#runpod api key
RUNPOD_API_KEY=your-runpod-api-key-here

# 로깅 설정
# 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# SSL 설정 (HTTPS 사용 시)
# CERTFILE=/path/to/certfile
# KEYFILE=/path/to/keyfile
